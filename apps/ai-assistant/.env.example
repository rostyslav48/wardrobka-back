RABBIT_MQ_URI=amqp://rabbitmq:5672
RABBIT_MQ_AI_ASSISTANT_QUEUE=ai-assistant
RABBIT_MQ_WARDROBE_QUEUE=wardrobe
RABBIT_MQ_MEDIA_STORAGE_QUEUE=media-storage

PROTECTED_DATA_SECRET=change-me
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
AI_ASSISTANT_WEBHOOK_URL=https://example.com/wardrobe-ai/webhook
AI_ASSISTANT_WEBHOOK_AUTH_HEADER=X-Wardrobe-AI-Key
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_INTERVAL_MS=60000

